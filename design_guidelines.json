  "universal_guidelines": {
    "general": [
      "No CSS/Tailwind classes. Use StyleSheet objects.",
      "Use SafeAreaView for all screens to handle notches.",
      "Touch targets must be at least 44x44 points.",
      "Text must have explicit colors defined (React Native defaults can vary).",
      "Images must have explicit width/height or flex style."
    ],
    "testing": [
      "Add testID props to all interactable elements for Detox/Appium.",
      "Mock Camera module for UI tests."
    ]
  },
  "instructions_to_main_agent": "You are building a React Native Expo app. Strictly use StyleSheet.create(). Do NOT use HTML tags (div, span). Use View, Text, Image, TouchableOpacity/Pressable. For the 'Analysis' screen, you must layer the <Svg> component absolutely over the <Image> component to draw the hold circles. The Grade should be prominent (Text 5xl). The 'Guest Mode' means no login screen on launch—go straight to Home or Onboarding."
